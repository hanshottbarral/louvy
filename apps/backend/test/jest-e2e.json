{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@korus/shared$": "<rootDir>/../../packages/shared/src/index.ts",
    "^@korus/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1"
  },
  "testEnvironment": "node"
}
